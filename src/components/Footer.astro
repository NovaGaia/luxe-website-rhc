---
// À compléter : liens, mentions légales, réseaux sociaux

interface Props {
  editUrl?: string;
}

const { editUrl } = Astro.props;
---

<footer>
  <!-- À remplir -->
</footer>

{import.meta.env.DEV && editUrl && (
  <div class="fixed bottom-4 right-4 z-9999">
    <a
      href={editUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block rounded px-4 py-2 text-xs font-semibold text-white no-underline bg-[#e25f21] hover:bg-[#c94e15] transition-colors"
    >
      ✏️ Éditer cette page
    </a>
  </div>
)}
