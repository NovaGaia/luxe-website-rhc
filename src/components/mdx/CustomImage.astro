---
import { tv } from 'tailwind-variants';
import type { ImageMetadata } from 'astro';
import ResponsiveImage from '../ResponsiveImage.astro';
import Caption from '../ui/Caption.astro';
import { getSizes } from '../../config/images';

type Position = 'full' | 'left' | 'right';
type Width = '1/4' | '1/2' | '2/3' | '3/4';

interface Props {
  src?: string;
  alt?: string;
  caption?: string;
  position?: Position;
  width?: Width;
  imgWidth?: number;
  imgHeight?: number;
  href?: string;
  /**
   * Override des tailles srcset pour cette image spécifique.
   * Par défaut : calculé depuis IMAGE_BREAKPOINTS (src/config/images.ts).
   * Ex : customSizes={[320, 640, 1280]}
   */
  customSizes?: number[];
}

const {
  src,
  alt = '',
  caption,
  position = 'full',
  width = '1/2',
  imgWidth,
  imgHeight,
  href,
  customSizes,
} = Astro.props;

if (!src) return;

const figure = tv({
  base: 'w-full',
  variants: {
    position: {
      full: 'my-6',
      left: 'my-4 md:float-left md:clear-left md:mr-6 md:mb-2',
      right: 'my-4 md:float-right md:clear-right md:ml-6 md:mb-2',
    },
    width: {
      '1/4': 'md:w-1/4',
      '1/2': 'md:w-1/2',
      '2/3': 'md:w-2/3',
      '3/4': 'md:w-3/4',
    },
  },
  compoundVariants: [{ position: 'full', class: 'md:w-full' }],
  defaultVariants: { position: 'full', width: '1/2' },
});

// Largeur d'affichage max par contexte (en supposant un contenu max-width ~1200px)
// Utilisée pour calculer les breakpoints retina pertinents via getSizes()
const maxDisplayWidthMap: Record<Position, Record<Width, number>> = {
  full:  { '1/4': 1200, '1/2': 1200, '2/3': 1200, '3/4': 1200 },
  left:  { '1/4': 300,  '1/2': 600,  '2/3': 800,  '3/4': 900  },
  right: { '1/4': 300,  '1/2': 600,  '2/3': 800,  '3/4': 900  },
};
const maxDisplayWidth = maxDisplayWidthMap[position][width];
const sizes = getSizes(maxDisplayWidth, customSizes);

// Attribut sizes CSS pour aider le navigateur à choisir la bonne variante
const sizesAttrMap: Record<Position, Record<Width, string>> = {
  full: { '1/4': '100vw', '1/2': '100vw', '2/3': '100vw', '3/4': '100vw' },
  left: {
    '1/4': '(min-width: 768px) 25vw, 100vw',
    '1/2': '(min-width: 768px) 50vw, 100vw',
    '2/3': '(min-width: 768px) 66vw, 100vw',
    '3/4': '(min-width: 768px) 75vw, 100vw',
  },
  right: {
    '1/4': '(min-width: 768px) 25vw, 100vw',
    '1/2': '(min-width: 768px) 50vw, 100vw',
    '2/3': '(min-width: 768px) 66vw, 100vw',
    '3/4': '(min-width: 768px) 75vw, 100vw',
  },
};
const sizesAttr = sizesAttrMap[position][width];

// TinaCMS stocke les images en /images/... (relatif à src/assets/)
// import.meta.glob : /src/assets/images/... → on préfixe le chemin TinaCMS
const isSvg = src.endsWith('.svg');
const isRemote = src.startsWith('http');
const imagePath = `/src/assets${src}`;

const imageGlob = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.{jpeg,jpg,png,gif,webp,avif}'
);

let resolvedImage: ImageMetadata | null = null;
if (!isSvg && !isRemote && imageGlob[imagePath]) {
  const mod = await imageGlob[imagePath]();
  resolvedImage = mod.default;
}
---

<figure class={figure({ position, width })}>
  {href ? (
    <a href={href} target="_blank" rel="noopener noreferrer">
      {resolvedImage ? (
        <ResponsiveImage
          src={resolvedImage}
          alt={alt}
          sizes={sizes}
          sizesAttr={sizesAttr}
          class="w-full h-auto"
        />
      ) : (
        <img
          src={src}
          alt={alt}
          width={imgWidth}
          height={imgHeight}
          loading="lazy"
          decoding="async"
          class="w-full h-auto"
        />
      )}
    </a>
  ) : resolvedImage ? (
    <ResponsiveImage
      src={resolvedImage}
      alt={alt}
      sizes={sizes}
      sizesAttr={sizesAttr}
      class="w-full h-auto"
    />
  ) : (
    <img
      src={src}
      alt={alt}
      width={imgWidth}
      height={imgHeight}
      loading="lazy"
      decoding="async"
      class="w-full h-auto"
    />
  )}
  {caption && <Caption>{caption}</Caption>}
</figure>
