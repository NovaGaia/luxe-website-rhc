---
import { tv } from 'tailwind-variants';

type ButtonStyle = 'primary' | 'secondary';

interface Props {
  href: string;
  label: string;
  style?: ButtonStyle;
  target?: '_self' | '_blank';
  rel?: string;
}

const { href, label, style = 'primary', target = '_self', rel } = Astro.props;

const resolvedRel = target === '_blank' ? (rel ?? 'noopener noreferrer') : rel;

const button = tv({
  base: 'inline-block px-8 py-3 font-semibold transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring',
  variants: {
    style: {
      primary: 'bg-primary text-primary-foreground hover:bg-primary/90',
      secondary: 'border-2 border-primary text-primary hover:bg-primary hover:text-primary-foreground',
    },
  },
  defaultVariants: {
    style: 'primary',
  },
});
---

<a href={href} target={target} rel={resolvedRel} class={button({ style })}>
  {label}
</a>
