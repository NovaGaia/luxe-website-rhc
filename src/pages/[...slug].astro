---
import { client } from '../../tina/__generated__/client';
import PageContent from '../components/PageContent';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const pagesResponse = await client.queries.pageConnection();
  return (
    pagesResponse.data.pageConnection.edges?.map((edge) => ({
      params: { slug: edge?.node?._sys.filename === 'home' ? undefined : edge?.node?._sys.filename },
      props: { filename: edge?.node?._sys.filename },
    })) ?? []
  );
}

const { filename } = Astro.props;

const [pageResponse, seoResponse] = await Promise.all([
  client.queries.page({ relativePath: `${filename}.mdx` }),
  client.queries.seo({ relativePath: 'global.json' }),
]);

const { data, query, variables } = pageResponse;
const globalSeo = seoResponse.data.seo;

const description = data.page.description || globalSeo.defaultDescription || '';
const ogImage = globalSeo.defaultOgImage || '';
---

<Layout
  title={data.page.title}
  description={description}
  ogImage={ogImage}
  siteName={globalSeo.siteName}
  titleTemplate={globalSeo.titleTemplate ?? '%s'}
  twitterHandle={globalSeo.twitterHandle ?? ''}
>
  <PageContent data={data} query={query} variables={variables} client:load />
</Layout>
