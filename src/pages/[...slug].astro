---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import globalSeo from '../content/seo/global.json';

// Composant React — rendu statique PROD (TinaMarkdown sans useTina)
import StaticPageContent from '../components/StaticPageContent';
// Composant React — chemin dev uniquement (useTina + preview temps réel)
import PageContent from '../components/PageContent';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((entry) => {
    // En Astro 5, entry.id inclut l'extension (.mdx) — on la retire pour le slug
    const filename = entry.id.replace(/\.mdx$/, '');
    return {
      params: { slug: filename === 'home' ? undefined : filename },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
// entry.id = 'home.mdx', 'about.mdx', etc.

const title = entry.data.title;
const description = entry.data.description || globalSeo.defaultDescription || '';
const ogImage = globalSeo.defaultOgImage || '';

// Build (astro build) : import.meta.env.PROD = true → StaticPageContent (TinaMarkdown, AST riche)
// Dev   (astro dev)   : import.meta.env.PROD = false → PageContent + useTina (live preview)

let tinaData: any = null;
let tinaQuery = '';
let tinaVariables: any = null;

const { client } = await import('../../tina/__generated__/client');
const pageResponse = await client.queries.page({ relativePath: entry.id });
tinaData = pageResponse.data;
tinaQuery = pageResponse.query;
tinaVariables = pageResponse.variables;
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  siteName={globalSeo.siteName}
  titleTemplate={globalSeo.titleTemplate ?? '%s'}
  twitterHandle={globalSeo.twitterHandle ?? ''}
>
  {import.meta.env.PROD ? (
    <StaticPageContent body={tinaData.page.body} client:load />
  ) : (
    <PageContent data={tinaData} query={tinaQuery} variables={tinaVariables} client:load />
  )}
</Layout>
